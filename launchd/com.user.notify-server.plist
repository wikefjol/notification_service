<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.notify-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/notify-server</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/USER/Library/Logs/notify-server.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/USER/Library/Logs/notify-server.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/USER</string>
    </dict>
</dict>
</plist>
